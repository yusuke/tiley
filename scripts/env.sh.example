#!/bin/zsh

# App Store Connect API credentials for notarization.
# Copy this file to env.sh and fill in your values:
#   cp scripts/env.sh.example scripts/env.sh

export API_ISSUER_ID=00000000-0000-0000-0000-000000000000
export API_KEY_ID=YOUR_KEY_ID
export API_KEY_PATH=/path/to/AuthKey_YOUR_KEY_ID.p8
